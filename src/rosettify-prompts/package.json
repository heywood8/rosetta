{
  "name": "rosettify-prompts",
  "version": "0.1.1",
  "description": "Bench/eval prompt variants using Anthropic: tokens, thinking tokens, cost, latency, and stability across repeated, concurrent runs",
  "license": "Apache-2.0",
  "author": "Rosetta Team <rosetta-support@griddynamics.com>",
  "homepage": "https://griddynamics.github.io/rosetta/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/griddynamics/rosetta.git"
  },
  "bugs": {
    "url": "https://github.com/griddynamics/rosetta/issues"
  },
  "type": "module",
  "bin": {
    "rosettify-prompts": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "env.template",
    "evals.json"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "bench": "tsx src/cli.ts",
    "start": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.0",
    "commander": "^14.0.3",
    "dotenv": "^17.2.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
