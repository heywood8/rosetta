# PyPI Configuration File for ims-mcp Publishing
# 
# ⚠️  SECURITY NOTICE ⚠️
# This file should contain a REAL project-scoped PyPI token for ims-mcp.
# 
# Token Details:
# - Scope: Project-specific (ims-mcp ONLY)
# - Permissions: Upload new versions to ims-mcp package only
# - Risk: Limited - can only affect the ims-mcp package
# 
# This token should be created for repository-based publishing.
# Anyone with repo access can publish updates to ims-mcp.
#
# To generate: https://pypi.org/manage/project/ims-mcp/settings/
#
# Steps:
# 1. First publish to PyPI using personal token (see PUBLISHING.md)
# 2. After first publish, create project-scoped token at URL above
# 3. Replace PLACEHOLDER below with actual token
# 4. Copy this file to .pypirc (already in .gitignore)

[distutils]
index-servers =
    pypi

[pypi]
username = __token__
password = PLACEHOLDER-GENERATE-TOKEN-AFTER-FIRST-PUBLISH
