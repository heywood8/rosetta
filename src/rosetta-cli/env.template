# RAGFlow Configuration Template
# Copy this file to .env and fill in your values

# RAGFlow Instance URL
# Local: http://localhost:80
# Remote: http://your-ragflow-instance
RAGFLOW_BASE_URL=http://your-ragflow-instance

# RAGFlow API Key
# Generate in RAGFlow UI: Profile → API Keys → Generate New Key
# Format: ragflow-xxxxxxxxxxxxxxxxxxxx
RAGFLOW_API_KEY=ragflow-xxxxxxxxxxxxxxxxxxxx

# Environment Name
ENVIRONMENT=local

# Dataset Configuration
# Default dataset name (used when no release specified)
RAGFLOW_DATASET_DEFAULT=aia

# Dataset name template
# Use {release} placeholder for release-based datasets
# Example: aia-{release} → aia-r1, aia-r2, etc.
RAGFLOW_DATASET_TEMPLATE=aia-{release}

# Dataset Creation Settings

# Embedding Model (format: model_name@provider)
# OpenAI options: text-embedding-3-small@OpenAI, text-embedding-3-large@OpenAI, text-embedding-ada-002@OpenAI
# Leave empty to use RAGFlow default (usually BAAI/bge-large-zh-v1.5)
RAGFLOW_EMBEDDING_MODEL=text-embedding-3-small@OpenAI
# Chunk Method: naive, qa, manual, table, paper, book, laws, presentation, picture, one, audio, email, tag
RAGFLOW_CHUNK_METHOD=naive
# Parser Configuration (for naive chunking)
# Chunk size in tokens (1-2048, default: 512)
RAGFLOW_CHUNK_TOKEN_NUM=512
# Delimiter for splitting chunks (default: \n)
RAGFLOW_DELIMITER=\n
# Auto-generate keywords per chunk (0-32, default: 0)
RAGFLOW_AUTO_KEYWORDS=0
# Auto-generate questions per chunk (0-10, default: 0)
RAGFLOW_AUTO_QUESTIONS=0
# Page size for listing operations (default: 1000)
RAGFLOW_PAGE_SIZE=1000
# Timeout for document parsing operations in seconds (default: 300 = 5 minutes)
RAGFLOW_PARSE_TIMEOUT=300

