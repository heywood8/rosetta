{
  "name": "rosettify-plugins",
  "version": "1.0.7",
  "description": "Generate Rosetta IDE plugin outputs from instruction sources via CLI or library API",
  "license": "Apache-2.0",
  "author": "isolomatovgd",
  "homepage": "https://griddynamics.github.io/rosetta/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/griddynamics/rosetta.git"
  },
  "bugs": {
    "url": "https://github.com/griddynamics/rosetta/issues"
  },
  "type": "module",
  "bin": {
    "rosettify-plugins": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "start": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "immer": "^10.1.1",
    "micromatch": "^4.0.8",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.5",
    "tsx": "^4.19.4",
    "typescript": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
