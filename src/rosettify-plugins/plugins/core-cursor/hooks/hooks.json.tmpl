{
  "version": 1,
  "hooks": {
{{#if deterministic_hooks}}
    "beforeReadFile": [
      {
        "command": "node hooks/read-once.js"
      }
    ],
    "beforeTabFileRead": [
      {
        "command": "node hooks/read-once.js"
      }
    ],
    "preCompact": [
      {
        "command": "node hooks/read-once-reset.js"
      }
    ],
    "preToolUse": [
      {
        "matcher": "Bash|Shell|Write|Edit|MultiEdit|mcp__.*",
        "command": "node hooks/dangerous-actions.js"
      },
      {
        "matcher": "Read|Bash|Shell",
        "command": "node hooks/read-once.js"
      }
    ],
    "postToolUse": [
      {
        "matcher": "Write",
        "command": "node hooks/loose-files.js"
      },
      {
        "matcher": "Write|Edit",
        "command": "node hooks/md-file-advisory.js"
      },
      {
        "matcher": "Write|Edit",
        "command": "node hooks/codemap-refresh.js"
      },
      {
        "matcher": "Write|Edit",
        "command": "node hooks/lint-format-advisory.js"
      }
    ]
{{/if}}
  }
}
