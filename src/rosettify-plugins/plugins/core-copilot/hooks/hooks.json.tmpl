{
  "version": 1,
  "hooks": {
    "sessionStart": []{{#if deterministic_hooks}},{{/if}}
{{#if deterministic_hooks}}
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|create_file|replace_string_in_file|multi_replace_string_in_file|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \".github/hooks/dangerous-actions.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|create_file",
        "hooks": [
          {
            "type": "command",
            "command": "node \".github/hooks/loose-files.js\""
          },
          {
            "type": "command",
            "command": "node \".github/hooks/md-file-advisory.js\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|create_file|replace_string_in_file|multi_replace_string_in_file",
        "hooks": [
          {
            "type": "command",
            "command": "node \".github/hooks/codemap-refresh.js\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|create_file|replace_string_in_file|multi_replace_string_in_file",
        "hooks": [
          {
            "type": "command",
            "command": "node \".github/hooks/lint-format-advisory.js\""
          }
        ]
      }
    ]
{{/if}}
  }
}
