{
  "feature": "workflow-docs",
  "description": "Parallel authoring and review of dedicated workflow documentation pages for the public website.",
  "steps": [
    {
      "id": "AUTHOR-INIT-WORKSPACE-FLOW",
      "output": "docs/web/docs/init-workspace-flow.md"
    },
    {
      "id": "AUTHOR-SELF-HELP-FLOW",
      "output": "docs/web/docs/self-help-flow.md"
    },
    {
      "id": "AUTHOR-CODING-FLOW",
      "output": "docs/web/docs/coding-flow.md"
    },
    {
      "id": "AUTHOR-REQUIREMENTS-AUTHORING-FLOW",
      "output": "docs/web/docs/requirements-authoring-flow.md"
    },
    {
      "id": "AUTHOR-ADHOC-FLOW",
      "output": "docs/web/docs/adhoc-flow.md"
    },
    {
      "id": "AUTHOR-CODE-ANALYSIS-FLOW",
      "output": "docs/web/docs/code-analysis-flow.md"
    },
    {
      "id": "AUTHOR-RESEARCH-FLOW",
      "output": "docs/web/docs/research-flow.md"
    },
    {
      "id": "AUTHOR-AQA-FLOW",
      "output": "docs/web/docs/aqa-flow.md"
    },
    {
      "id": "AUTHOR-TESTGEN-FLOW",
      "output": "docs/web/docs/testgen-flow.md"
    },
    {
      "id": "AUTHOR-MODERNIZATION-FLOW",
      "output": "docs/web/docs/modernization-flow.md"
    },
    {
      "id": "AUTHOR-EXTERNAL-LIB-FLOW",
      "output": "docs/web/docs/external-lib-flow.md"
    },
    {
      "id": "AUTHOR-CODING-AGENTS-PROMPTING-FLOW",
      "output": "docs/web/docs/coding-agents-prompting-flow.md"
    },
    {
      "id": "INTEGRATION-WORKFLOW-DOCS",
      "output": "docs/web/docs/usage-guide.md, docs/web/_layouts/docs.html"
    }
  ]
}
